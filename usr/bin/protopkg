#!/bin/sh
# protopkg - ProtOS Package Manager
# A lightweight package manager for ProtOS using static binaries

VERSION="0.1.0"
REPO_URL="${PROTOPKG_REPO:-}"
DB_DIR="/var/lib/protopkg"
CACHE_DIR="/var/cache/protopkg"
INDEX_FILE="$DB_DIR/PACKAGES.idx"
INSTALLED_DIR="$DB_DIR/installed"
LOCK_FILE="$DB_DIR/protopkg.lock"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

msg()  { printf "${BLUE}::${NC} %s\n" "$1"; }
ok()   { printf "${GREEN}>>>${NC} %s\n" "$1"; }
warn() { printf "${YELLOW}warning:${NC} %s\n" "$1"; }
err()  { printf "${RED}error:${NC} %s\n" "$1" >&2; }
die()  { err "$1"; exit 1; }

acquire_lock() {
    if [ -f "$LOCK_FILE" ]; then
        local pid
        pid=$(cat "$LOCK_FILE" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            die "Another protopkg process is running (pid $pid)"
        fi
    fi
    echo $$ > "$LOCK_FILE"
    trap 'rm -f "$LOCK_FILE"' EXIT
}

release_lock() {
    rm -f "$LOCK_FILE"
    trap - EXIT
}

# Ensure required directories exist
init_dirs() {
    mkdir -p "$DB_DIR" "$CACHE_DIR" "$INSTALLED_DIR"
}

# Load repo URL from config
load_config() {
    if [ -z "$REPO_URL" ] && [ -f "$DB_DIR/repo.conf" ]; then
        REPO_URL=$(head -1 "$DB_DIR/repo.conf" | tr -d '[:space:]')
    fi
}

# SYNC

# Download the package index from the repo
cmd_sync() {
    load_config
    [ -z "$REPO_URL" ] && die "No repository configured. Run: protopkg repo <url>"

    msg "Synchronizing package index..."
    local url="${REPO_URL%/}/PACKAGES.idx"

    if wget -q -O "$INDEX_FILE.tmp" "$url" 2>/dev/null; then
        mv "$INDEX_FILE.tmp" "$INDEX_FILE"
        local count
        count=$(wc -l < "$INDEX_FILE" | tr -d ' ')
        ok "Package index synced ($count packages)"
    else
        rm -f "$INDEX_FILE.tmp"
        die "Failed to fetch index from $url"
    fi
}

# SEARXH 
# Search the package index
cmd_search() {
    [ -z "$1" ] && die "Usage: protopkg search <term>"
    [ ! -f "$INDEX_FILE" ] && die "No package index. Run: proopkg sync"

    local term="$1"
    printf "${BOLD}%-20s %-12s %s${NC}\n" "Name" "Version" "Description"
    printf "%-20s %-12s %s\n" "----" "-------" "-----------"

    grep -i "$term" "$INDEX_FILE" 2>/dev/null | while IFS='|' read -r name ver arch deps size sha desc; do
        local installed=""
        [ -d "$INSTALLED_DIR/$name" ] && installed=" ${GREEN}[installed]${NC}"
        printf "%-20s %-12s %b\n" "$name" "$ver" "${desc}${installed}"
    done
}

# INFO
# Show package details
cmd_info() {
    [ -z "$1" ] && die "Usage: protopkg info <package>"
    [ ! -f "$INDEX_FILE" ] && die "No package index. Run: protopkg sync"

    local name="$1"
    local entry
    entry=$(grep "^${name}|" "$INDEX_FILE" 2>/dev/null | head -1)
    [ -z "$entry" ] && die "Package '$name' not found"

    local ver arch deps size sha desc
    IFS='|' read -r name ver arch deps size sha desc <<EOF
$entry
EOF

    printf "${BOLD}Name:${NC}         %s\n" "$name"
    printf "${BOLD}Version:${NC}      %s\n" "$ver"
    printf "${BOLD}Architecture:${NC} %s\n" "$arch"
    printf "${BOLD}Size:${NC}         %s bytes\n" "$size"
    printf "${BOLD}Description:${NC}  %s\n" "$desc"

    if [ -n "$deps" ] && [ "$deps" != "-" ]; then
        printf "${BOLD}Depends on:${NC}   %s\n" "$deps"
    else
        printf "${BOLD}Depends on:${NC}   (none)\n"
    fi

    if [ -d "$INSTALLED_DIR/$name" ]; then
        printf "${BOLD}Status:${NC}       ${GREEN}installed${NC}\n"
        if [ -f "$INSTALLED_DIR/$name/PKGINFO" ]; then
            local iver
            iver=$(grep '^version=' "$INSTALLED_DIR/$name/PKGINFO" | cut -d= -f2)
            printf "${BOLD}Installed:${NC}    %s\n" "$iver"
        fi
    else
        printf "${BOLD}Status:${NC}       not installed\n"
    fi
}

# RESOLVE_DEOS
# Recursively resolve dependencies, returns list in install order
resolve_deps() {
    local pkg="$1"
    local _visited="$2"

    # Avoid circular deps
    echo "$_visited" | grep -q " ${pkg} " && return 0

    local entry
    entry=$(grep "^${pkg}|" "$INDEX_FILE" 2>/dev/null | head -1)
    [ -z "$entry" ] && { echo "warning: Dependency '$pkg' not found in index" >&2; return 1; }

    local name ver arch deps size sha desc
    IFS='|' read -r name ver arch deps size sha desc <<EOF
$entry
EOF

    _visited="$_visited ${pkg} "

    # Resolve sub-dependencies first
    if [ -n "$deps" ] && [ "$deps" != "-" ]; then
        for dep in $deps; do
            # Skip if already installed
            [ -d "$INSTALLED_DIR/$dep" ] && continue
            resolve_deps "$dep" "$_visited"
        done
    fi

    # Print this package if not already installed
    [ ! -d "$INSTALLED_DIR/$pkg" ] && echo "$pkg"

    return 0
}

# ── install ───────────────────────────────────────────
# Install one or more packages
cmd_install() {
    [ -z "$1" ] && die "Usage: protopkg install <package> [package...]"
    [ ! -f "$INDEX_FILE" ] && die "No package index. Run: protopkg sync"
    load_config

    local to_install=""
    local total_size=0

    # Resolve all packages and their deps
    for pkg in "$@"; do
        if [ -d "$INSTALLED_DIR/$pkg" ]; then
            warn "'$pkg' is already installed -- skipping"
            continue
        fi

        local entry
        entry=$(grep "^${pkg}|" "$INDEX_FILE" 2>/dev/null | head -1)
        [ -z "$entry" ] && die "Package '$pkg' not found"

        # Get dependency chain
        local chain
        chain=$(resolve_deps "$pkg" " ")
        for p in $chain; do
            # Deduplicate
            echo "$to_install" | grep -q " ${p} " || {
                to_install="$to_install ${p} "
                local psize
                psize=$(grep "^${p}|" "$INDEX_FILE" | cut -d'|' -f5)
                total_size=$((total_size + ${psize:-0}))
            }
        done
    done

    # Nothing to do?
    to_install=$(echo "$to_install" | xargs)
    [ -z "$to_install" ] && { ok "Nothing to do."; return 0; }

    # Show what will be installed
    local count
    count=$(echo "$to_install" | wc -w | tr -d ' ')
    msg "Packages ($count): $to_install"

    local human_size
    if [ "$total_size" -gt 1048576 ] 2>/dev/null; then
        human_size="$((total_size / 1048576)) MiB"
    elif [ "$total_size" -gt 1024 ] 2>/dev/null; then
        human_size="$((total_size / 1024)) KiB"
    else
        human_size="${total_size} B"
    fi
    printf "\nTotal download size: %s\n\n" "$human_size"

    # Confirm
    printf "Proceed with installation? [Y/n] "
    read -r ans
    case "$ans" in
        n|N|no|No) echo "Aborted."; return 1 ;;
    esac

    # Download and install each package
    for pkg in $to_install; do
        install_one "$pkg"
    done

    echo ""
    ok "Done! $count package(s) installed."
}

# Install a single package
install_one() {
    local pkg="$1"
    local entry
    entry=$(grep "^${pkg}|" "$INDEX_FILE" | head -1)
    local name ver arch deps size sha desc
    IFS='|' read -r name ver arch deps size sha desc <<EOF
$entry
EOF

    local filename="${name}-${ver}-${arch}.pkg.tar.gz"
    local filepath="$CACHE_DIR/$filename"
    local url="${REPO_URL%/}/${filename}"

    # Download if not cached
    if [ ! -f "$filepath" ]; then
        msg "Downloading $filename..."
        if ! wget -q -O "$filepath.tmp" "$url" 2>/dev/null; then
            rm -f "$filepath.tmp"
            die "Failed to download $url"
        fi
        mv "$filepath.tmp" "$filepath"
    fi

    # Verify checksum
    if [ -n "$sha" ] && [ "$sha" != "-" ]; then
        local actual
        actual=$(sha256sum "$filepath" 2>/dev/null | cut -d' ' -f1)
        if [ "$actual" != "$sha" ]; then
            rm -f "$filepath"
            die "Checksum mismatch for $filename"
        fi
    fi

    # Extract
    msg "Installing $name ($ver)..."

    # Extract to temp dir first
    local tmpdir="/tmp/protopkg-install-$$"
    rm -rf "$tmpdir"
    mkdir -p "$tmpdir"
    tar xzf "$filepath" -C "$tmpdir" 2>/dev/null

    # Read package PKGINFO
    if [ ! -f "$tmpdir/PKGINFO" ]; then
        rm -rf "$tmpdir"
        die "Invalid package: missing PKGINFO"
    fi

    # Generate file list from data/
    local filelist=""
    if [ -d "$tmpdir/data" ]; then
        filelist=$(cd "$tmpdir/data" && find . -type f -o -type l | sed 's|^\./|/|' | sort)

        # Install files to root
        (cd "$tmpdir/data" && tar cf - . | tar xf - -C /) || warn "Some files may not have been extracted cleanly"
        # Run post-install script if present
        if [ -f "$tmpdir/post-install.sh" ]; then
            sh "$tmpdir/post-install.sh" 2>/dev/null || true
        fi
    fi

    # Record installation
    mkdir -p "$INSTALLED_DIR/$name"
    cp "$tmpdir/PKGINFO" "$INSTALLED_DIR/$name/PKGINFO"
    echo "$filelist" > "$INSTALLED_DIR/$name/FILES"

    rm -rf "$tmpdir"
    ok "Installed $name $ver"
}

# ── remove ────────────────────────────────────────────
# Remove an installed package
cmd_remove() {
    [ -z "$1" ] && die "Usage: protopkg remove <package> [package...]"

    for pkg in "$@"; do
        if [ ! -d "$INSTALLED_DIR/$pkg" ]; then
            warn "'$pkg' is not installed"
            continue
        fi

        local ver=""
        [ -f "$INSTALLED_DIR/$pkg/PKGINFO" ] && \
            ver=$(grep '^version=' "$INSTALLED_DIR/$pkg/PKGINFO" | cut -d= -f2)

        msg "Removing $pkg ${ver:+($ver)}..."

        # Delete installed files
        if [ -f "$INSTALLED_DIR/$pkg/FILES" ]; then
            # Remove files (not directories) in reverse order
            sort -r "$INSTALLED_DIR/$pkg/FILES" | while IFS= read -r file; do
                [ -z "$file" ] && continue
                if [ -f "$file" ] || [ -L "$file" ]; then
                    rm -f "$file"
                fi
            done
            # Try to remove empty directories (will fail silently if not empty)
            sort -r "$INSTALLED_DIR/$pkg/FILES" | while IFS= read -r file; do
                [ -z "$file" ] && continue
                local dir
                dir=$(dirname "$file")
                rmdir "$dir" 2>/dev/null || true
            done
        fi

        # Remove from database
        rm -rf "$INSTALLED_DIR/$pkg"
        ok "Removed $pkg"
    done
}

# ── list ──────────────────────────────────────────────
# List installed packages
cmd_list() {
    if [ ! -d "$INSTALLED_DIR" ] || [ -z "$(ls "$INSTALLED_DIR" 2>/dev/null)" ]; then
        echo "No packages installed."
        return 0
    fi

    printf "${BOLD}%-20s %-12s %s${NC}\n" "Name" "Version" "Description"
    printf "%-20s %-12s %s\n" "----" "-------" "-----------"

    for pkg_dir in "$INSTALLED_DIR"/*/; do
        [ -d "$pkg_dir" ] || continue
        local name
        name=$(basename "$pkg_dir")
        local ver="" desc=""
        if [ -f "$pkg_dir/PKGINFO" ]; then
            ver=$(grep '^version=' "$pkg_dir/PKGINFO" | cut -d= -f2)
            desc=$(grep '^desc=' "$pkg_dir/PKGINFO" | cut -d= -f2)
        fi
        printf "%-20s %-12s %s\n" "$name" "$ver" "$desc"
    done
}

# ── files ─────────────────────────────────────────────
# List files owned by a package
cmd_files() {
    [ -z "$1" ] && die "Usage: protopkg files <package>"

    if [ ! -d "$INSTALLED_DIR/$1" ]; then
        die "Package '$1' is not installed"
    fi

    if [ -f "$INSTALLED_DIR/$1/FILES" ]; then
        cat "$INSTALLED_DIR/$1/FILES"
    else
        echo "(no file list)"
    fi
}

# ── repo ──────────────────────────────────────────────
# Set the repository URL
cmd_repo() {
    if [ -z "$1" ]; then
        load_config
        if [ -n "$REPO_URL" ]; then
            echo "Current repo: $REPO_URL"
        else
            echo "No repository configured."
            echo "Usage: protopkg repo <url>"
        fi
        return 0
    fi

    local url="$1"
    mkdir -p "$DB_DIR"
    echo "$url" > "$DB_DIR/repo.conf"
    ok "Repository set to: $url"
}

# ── upgrade ───────────────────────────────────────────
# Check for and install updates
cmd_upgrade() {
    [ ! -f "$INDEX_FILE" ] && die "No package index. Run: protopkg sync"
    load_config

    local upgrades=""
    for pkg_dir in "$INSTALLED_DIR"/*/; do
        [ -d "$pkg_dir" ] || continue
        local name
        name=$(basename "$pkg_dir")
        local iver=""
        [ -f "$pkg_dir/PKGINFO" ] && iver=$(grep '^version=' "$pkg_dir/PKGINFO" | cut -d= -f2)

        local entry
        entry=$(grep "^${name}|" "$INDEX_FILE" 2>/dev/null | head -1)
        [ -z "$entry" ] && continue

        local rver
        rver=$(echo "$entry" | cut -d'|' -f2)

        if [ -n "$iver" ] && [ -n "$rver" ] && [ "$iver" != "$rver" ]; then
            upgrades="$upgrades $name"
            printf " &s : &s -> %s\n" "$name" "$iver" "$rver"
        fi

    done

    if [ -z "$upgrades" ]; then
        ok "Everything is up to date."
        return 0
    fi

    printf "\nProceed with upgrade? [Y/n] "
    read -r ans
    case "$ans" in
        n|N|no|No) echo "Aborted."; return 1 ;;
    esac

    for pkg in $upgrades; do
        # Remove old, install new
        rm -rf "$INSTALLED_DIR/$pkg"
        install_one "$pkg"
    done

    ok "Upgrade complete."
}

# ── main ──────────────────────────────────────────────
usage() {
    cat <<EOF
protopkg - ProtOS Package Manager v${VERSION}

Usage: protopkg <command> [options]

Commands:
  sync              Synchronize package index from repository
  install <pkg>     Install package(s) and dependencies
  remove <pkg>      Remove package(s)
  upgrade           Upgrade all installed packages
  search <term>     Search for packages
  info <pkg>        Show package details
  list              List installed packages
  files <pkg>       List files owned by a package
  repo [url]        Show or set repository URL

Examples:
  protopkg repo https://your-server.com/protos-repo
  protopkg sync
  protopkg install nano
  protopkg search editor
EOF
}

init_dirs

case "${1:-}" in
    sync)     acquire_lock; cmd_sync ;;
    install)  shift; acquire_lock; cmd_install "$@" ;;
    remove)   shift; acquire_lock; cmd_remove "$@" ;;
    upgrade)  acquire_lock; cmd_upgrade ;;
    search)   shift; cmd_search "$@" ;;
    info)     shift; cmd_info "$@" ;;
    list)     cmd_list ;;
    files)    shift; cmd_files "$@" ;;
    repo)     shift; cmd_repo "$@" ;;
    version|-v|--version) echo "protopkg $VERSION" ;;
    help|-h|--help) usage ;;
    *)        usage; exit 1 ;;
esac
