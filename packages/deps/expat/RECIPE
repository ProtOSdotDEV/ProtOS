#!/bin/sh

pkgname="expat"
pkgver="2.6.4"
pkgdesc="XML parsing library"
pkgarch="aarch64"
pkgdeps="-"

build() {
    wget -q "https://github.com/libexpat/libexpat/releases/download/R_$(echo ${pkgver} |tr '.' '_')/expat-${pkgver}.tar.gz" -O ${pkgname}.tar.gz
    tar xf ${pkgname}.tar.gz
    cd ${pkgname}-${pkgver}
    ./configure \
        --prefix=/usr \
        --enable-shared \
        --disable-static \
        --without-docbook 
    make -j$(nproc)
}

package() {
    cd "$BUILDDIR/src/${pkgname}-${pkgver}"
    make DESTDIR="$PKGDIR/data" install
    rm -f "$PKGDIR/data/usr/lib"*.a
    rm -f "$PKGDIR/data/usr/lib"*.la
    rm -rf "$PKGDIR/data/usr/bin"
    rm -rf "$PKGDIR/data/usr/share"
}