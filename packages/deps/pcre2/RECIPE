#!/bin/sh

pkgname="pcre2"
pkgver="10.44"
pkgdesc="Perl Compatible Regular Expressions Library"
pkgarch="aarch64"
pkgdeps="-"

build() {
    wget -q "https://github.com/PCRE2Project/${pkgname}/releases/download/${pkgname}-${pkgver}/${pkgname}-${pkgver}.tar.gz" -O ${pkgname}.tar.gz
    tar xf ${pkgname}.tar.gz
    cd ${pkgname}-${pkgver}
    ./configure \
        --prefix=/usr \
        --enable-shared \
        --disable-static \
        --enable-${pkgname}-8 \
        --enable-${pkgname}-16 \
        --enable-${pkgname}-32 \
        --enable-unicode \
        --disable-pcre2grep-libz \
        --disable-pcre2grep-libz2 \
        --disable-pcre2test-libreadline
    make -j$(nproc)
}

package() {
    cd "$BUILDDIR/src/${pkgname}-${pkgver}"
    make DESTDIR="$PKGDIR/data" install
    rm -f "$PKGDIR/data/usr/lib/"*.a
    rm -f "$PKGDIR/data/usr/lib/"*.la
    rm -rf "$PKGDIR/data/usr/share"
}
